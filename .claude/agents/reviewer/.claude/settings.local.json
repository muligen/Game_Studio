{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "MultiEdit(*)"
    ]
  },
  "env": {
    "TRACE_TO_LANGFUSE": "true"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python \"../../hooks/langfuse_hook.py\""
          }
        ]
      }
    ]
  }
}
